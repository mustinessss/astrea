# Скопируй в .env и заполни своими значениями.

# Подключение к Postgres. Примеры:
#   локально:           postgresql://developer:mustiness@localhost:5432/steel_dawn
#   докер:              postgresql://postgres:postgres@db:5432/astrea
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# Секрет для подписи JWT. Сгенерировать можно так:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-random-string

# (необязательно) Срок жизни access-токена, минут
ACCESS_TOKEN_EXPIRE_MINUTES=480
